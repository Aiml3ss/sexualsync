{
  "id": "/",
  "name": "Sexualsync",
  "short_name": "Sexualsync",
  "description": "The private room for couples to share kinks, drop fantasies, and finally ask for the thing.",
  "start_url": "/signin?source=pwa",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui", "browser"],
  "background_color": "#170a10",
  "theme_color": "#170a10",
  "orientation": "portrait",
  "categories": ["lifestyle", "social"],
  "share_target": {
    "action": "/share",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
