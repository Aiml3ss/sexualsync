# Sexualsync — Self-Host (Node) edition environment template
#
# STATUS: RUNNABLE (Phase 1). The Node runtime ships today: it runs the SAME
# product code as Cloudflare on filesystem-backed storage, with the live
# realtime room in-process and a working Docker image (CI builds the image and
# boots the container on every change). Copy this to .env.selfhost, fill in real
# values, and run `npm run selfhost:serve` or `docker compose up --build`. See
# selfhost/README.md and docs/self-host/.
#
# Only the SCALE-OUT backends are not wired yet: the DATABASE_URL / S3_* / SMTP_*
# variables below are PLACEHOLDERS for the multi-process adapters that do not
# exist yet (see docs/self-host/MIGRATION_PLAN.md) — setting them today has no
# effect. Single-node self-hosting needs NONE of them; the filesystem store +
# media adapters and the in-process realtime room cover it.
#
# The live production app runs on Cloudflare and uses /.env.example, NOT this
# file.
#
# Never commit real secret values.

# --- Runtime selector ---
# THE deployment-level switch. Default (when unset) is "cloudflare".
# Set to "node" to opt a deployment into the self-host edition.
# Any unrecognized value falls back to "cloudflare".
SELF_HOST_TARGET=node
# Built-in local email/password accounts are enabled automatically for the
# self-host Node runtime. Google/Resend below are optional extra sign-in methods.

# Node HTTP listen port.
PORT=8788
# Optional listen address. Required with ALLOW_LOCAL_PREVIEW=1 because dev
# identity is refused on public binds.
# HOST=127.0.0.1
# ALLOW_LOCAL_PREVIEW=1

# Reverse proxy. Leave UNSET (default false) for direct / localhost runs — the
# server then ignores X-Forwarded-* headers, so a client can't forge the
# origin/proto used by Secure-cookie and CSRF/origin checks. Set true ONLY when
# running behind a TLS-terminating reverse proxy (Caddy/nginx/Traefik) so OAuth
# redirects and origin checks see the real public https origin.
# NOTE: TRUST_PROXY=true is INCOMPATIBLE with ALLOW_LOCAL_PREVIEW=1 — together,
# a spoofed X-Forwarded-For could claim the unauthenticated local-preview
# identity, so the server refuses to boot with both set. Local preview is
# loopback-only dev; never run it behind a proxy.
# TRUST_PROXY=true

# --- Shared product config (same as Cloudflare) ---
# Optional first-party Google OAuth. On self-host, register your own origin/redirect:
#   Authorized origin:       https://your-host.example
#   Authorized redirect URI: https://your-host.example/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# OPTIONAL on self-host: if left blank, the Node server auto-generates a strong
# 256-bit secret on first boot and persists it to <data dir>/session-secret
# (0600) — so sessions + at-rest encryption work with zero setup. Set it
# explicitly only if you want to control/rotate it or share one across hosts.
# Once data exists, keep it stable: deleting the file or removing a value you
# previously set logs everyone out and makes at-rest data unreadable.
APP_SESSION_SECRET=
# REQUIRED for Google OAuth / email-code auth: replace this with your public
# origin. Local email/password auth does not need it on localhost. The server
# warns if the placeholder survives startup.
# When TRUST_PROXY=true, this origin's host also seeds the X-Forwarded-Host
# allowlist: only a forwarded host matching AUTH_BASE_URL/PUBLIC_BASE_URL is
# trusted, so a spoofed proxy header can't redirect emailed links or cookies.
AUTH_BASE_URL=https://your-host.example
# Optional. Canonical public origin for absolute links in transactional email.
# Defaults to AUTH_BASE_URL (precedence: PUBLIC_BASE_URL → AUTH_BASE_URL →
# request origin). Set only to decouple email links from the OAuth origin.
# PUBLIC_BASE_URL=https://your-host.example
SEXUALSYNC_ADMIN_EMAIL=

# Access gate (mirrors the Cloudflare app). The instance is PRIVATE by default:
# with PUBLIC_SIGNUPS_OPEN unset, only the emails listed below can create
# local/Google/email-code sessions. For a private 2-person self-host, replace
# the placeholder emails with both partners' real emails. Placeholder emails are
# ignored by local password auth so first-run Docker stays usable; the server
# also warns on placeholders. SEXUALSYNC_ADMIN_EMAIL (above) is always allowed.
PRIVATE_PREVIEW_ALLOWED_EMAILS=you@example.com,partner@example.com
# Leave UNSET to stay private. Set to 1 ONLY to drop the allow-list and accept
# open sign-ups (do not do this for a couple instance).
PUBLIC_SIGNUPS_OPEN=

# Shared couple workspace provisioning. Set this to your two emails so the
# shared room exists on first sign-in (same mechanism the Cloudflare app uses
# for the known couple). Without it, a new user signs in but has no workspace
# until one is created in-app. JSON form is preferred; or use the CSV pair.
LEGACY_MEMBERS_JSON=[{"email":"you@example.com","displayName":"You"},{"email":"partner@example.com","displayName":"Partner"}]
# LEGACY_MEMBER_EMAILS=you@example.com,partner@example.com
# LEGACY_MEMBER_NAMES=You,Partner

# At-rest JSON encryption (backend-agnostic; falls back to APP_SESSION_SECRET).
DATA_ENCRYPTION_KEY_V1=
# Secure-by-default: sensitive stores refuse to write plaintext when no key
# resolves. Leave UNSET. Set to 1 only if you deliberately run keyless because
# you encrypt at the disk/DB layer instead.
# ALLOW_PLAINTEXT_AT_REST=1

# Room Encryption passphrase KDF version for NEW rooms.
#   v1 = PBKDF2-SHA256 @ 310k (default — matches Cloudflare production)
#   v2 = PBKDF2-SHA256 @ 600k (OWASP 2023; recommended for self-host)
# Only NEW rooms are affected — each room freezes its KDF version into its
# verifier at enable time, so existing rooms keep deriving at their original
# count and stay readable. Unset or any unrecognized value resolves to v1.
ROOM_E2EE_KDF_VERSION=v2

# Web Push.
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@your-host.example

# Optional AI helpers. Off by default and fully opt-in.
# LLM_ENABLED=1   # required to turn AI on; off by default (also needs URL + key)
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Optional diagnostics.
SENTRY_DSN_PUBLIC=

APP_VERSION=sexualsync-selfhost-dev

# --- PLACEHOLDER: StoreAdapter (Postgres/SQLite) — checklist item 1, not wired ---
# Use ONE of these. Replaces the Cloudflare KV `STORE` binding.
DATABASE_URL=postgres://sexualsync:password@localhost:5432/sexualsync
# SQLITE_PATH=./data/sexualsync.sqlite

# --- PLACEHOLDER: ObjectStorageAdapter (S3/MinIO) — checklist item 2, not wired ---
# Replaces the Cloudflare R2 `VAULT_MEDIA` binding. Stores E2EE ciphertext only.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=sexualsync-vault-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- Realtime (live room) ---
# WORKS OUT OF THE BOX, single-process: WebSocket upgrades on /api/room/socket
# are served in-process (no config needed). The vars below are PLACEHOLDERS for
# a future MULTI-PROCESS deployment only — leave unset for single-instance.
#
# ROOM_WS_URL / ROOM_WS_TOKEN  — external realtime backplane (multi-process fan-out).
# STATE_ADVISORY_LOCK          — Postgres advisory-lock CAS (multi-process). Empty => in-process lock.
ROOM_WS_URL=
ROOM_WS_TOKEN=
STATE_ADVISORY_LOCK=

# --- PLACEHOLDER: SMTP email — checklist item 5, not wired ---
# Alternative to Resend. Keep the From display name generic (lock-screen safety).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Notifications <notifications@your-host.example>
# Or keep using Resend on self-host:
# RESEND_API_KEY=
